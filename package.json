    "./core": {
      "types": "./src/core.ts",
      "module-sync": "./dist/core.js",
      "import": "./dist/core.js"
    },
    "./model": {
      "types": "./src/model.ts",
      "module-sync": "./dist/model.js",
      "import": "./dist/model.js"
    },
