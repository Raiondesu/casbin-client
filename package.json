{
  "name": "casbin-client",
  "version": "1.0.0",
  "type": "module",
  "types": "src",
  "description": "Lightweight client for Casbin",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "url": "git+https://github.com/Raiondesu/casbin-client.git"
  },
  "author": {
    "name": "Raiondesu",
    "url": "https://github.com/raiondesu"
  },
  "module": "dist/index.js",
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "badge-maker": "^5.0.2",
    "coverage-percentage": "^0.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "typescript": "^5",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "exports": {
