      "types": "./src/policy.ts",
      "module-sync": "./dist/policy.js",
      "import": "./dist/policy.js"
    },
    "./parser": {
      "types": "./src/parser.ts",
      "module-sync": "./dist/parser.js",
      "import": "./dist/parser.js"
    },
    "./functions": {
      "types": "./src/functions.ts",
      "module-sync": "./dist/functions.js",
      "import": "./dist/functions.js"
    },
    "./react": {
      "types": "./src/react.ts",
      "module-sync": "./dist/react.js",
      "import": "./dist/react.js"
    },
    "./min": {
      "types": "./src/index.ts",
      "module-sync": "./dist/min/index.js",
      "import": "./dist/min/index.js"
    },
    "./min/core": {
      "types": "./src/core.ts",
      "module-sync": "./dist/min/core.js",
      "import": "./dist/min/core.js"
    },
    "./min/model": {
      "types": "./src/model.ts",
      "module-sync": "./dist/min/model.js",
      "import": "./dist/min/model.js"
    },
    "./min/policy": {
      "types": "./src/policy.ts",
      "module-sync": "./dist/min/policy.js",
      "import": "./dist/min/policy.js"
    },
    "./min/parser": {
      "types": "./src/parser.ts",
      "module-sync": "./dist/min/parser.js",
      "import": "./dist/min/parser.js"
    },
    "./min/functions": {
      "types": "./src/functions.ts",
      "module-sync": "./dist/min/functions.js",
      "import": "./dist/min/functions.js"
    },
    "./min/react": {
      "types": "./src/react.ts",
      "module-sync": "./dist/min/react.js",
      "import": "./dist/min/react.js"
    }
